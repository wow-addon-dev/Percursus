{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build WoW Addon - Percursus",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\..\\release-script\\local-build\\build-addon.ps1",
        "-ProjectRoot",
        "${workspaceFolder}"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
